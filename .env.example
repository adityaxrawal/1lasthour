# =============================================================================
# 1LastHour Backend — Environment Variables Template
# Copy this to .env and fill in real values
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://lasthour_user:password@localhost:5432/lasthour
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_TIMEOUT_MS=5000

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_DEFAULT=86400

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate keys with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then encode newlines as \n for use in .env:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:1223
ALLOWED_ORIGIN=http://localhost:1223

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_SEARCH=30
RATE_LIMIT_AUTH=10

# ─── Security Secrets (generate with: openssl rand -hex 32) ──────────────────
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
IP_SALT=CHANGE_ME_generate_with_openssl_rand_hex_16
REQUEST_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
